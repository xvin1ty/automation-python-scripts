# Polymarket Trading Bot Configuration
# Copy this file to .env and fill in your values

# ============================================
# WALLET CONFIGURATION (REQUIRED)
# ============================================

# Your Polygon wallet private key (KEEP THIS SECRET!)
# Format: 0x followed by 64 hex characters
POLYGON_PRIVATE_KEY=0x

# Your wallet address (the funder address)
WALLET_ADDRESS=0x

# Signature Type: 0 = EOA (MetaMask), 1 = Email/Magic, 2 = Gnosis Safe
SIGNATURE_TYPE=0

# ============================================
# API CONFIGURATION
# ============================================

# CLOB API Endpoint
CLOB_HOST=https://clob.polymarket.com

# Gamma API Endpoint
GAMMA_API_URL=https://gamma-api.polymarket.com

# Chain ID (137 = Polygon Mainnet)
CHAIN_ID=137

# API Credentials (auto-generated on first run)
API_KEY=
API_SECRET=
API_PASSPHRASE=

# ============================================
# TRADING CONFIGURATION
# ============================================

# Trading Mode: PAPER or LIVE
TRADING_MODE=PAPER

# Maximum position size in USDC
MAX_POSITION_SIZE=100

# Total trading capital
TOTAL_CAPITAL=1000

# Risk per trade (% of capital)
RISK_PER_TRADE=2

# Maximum open positions
MAX_OPEN_POSITIONS=5

# Default slippage tolerance (%)
DEFAULT_SLIPPAGE=0.5

# ============================================
# STRATEGY CONFIGURATION
# ============================================

# Enable/Disable Strategies
ENABLE_ARBITRAGE=true
ENABLE_MARKET_MAKING=false
ENABLE_TREND_FOLLOWING=true
ENABLE_NEWS_TRADING=false

# Arbitrage Settings
MIN_ARBITRAGE_SPREAD=0.02
MAX_ARBITRAGE_HOLD_TIME=3600

# Market Making Settings
MM_SPREAD_BASIS_POINTS=50
MM_ORDER_SIZE=50

# Trend Following Settings
TREND_LOOKBACK_PERIOD=20
TREND_THRESHOLD=0.05

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================

# Telegram Bot Token (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=

# ============================================
# DATABASE & LOGGING
# ============================================

# Database URL
DATABASE_URL=sqlite:///data/trading_bot.db

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log to file
LOG_TO_FILE=true
LOG_FILE_PATH=logs/bot.log

# ============================================
# ADVANCED SETTINGS
# ============================================

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# WebSocket reconnect delay (seconds)
WS_RECONNECT_DELAY=5

# Price update interval (seconds)
PRICE_UPDATE_INTERVAL=5

# Order refresh interval (seconds)
ORDER_REFRESH_INTERVAL=60

# Enable debug mode
DEBUG=false
